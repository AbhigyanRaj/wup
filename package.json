{
  "name": "wup-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Unified Brain - AI-powered multi-source database intelligence platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/link-web-native-deps.cjs",
    "dev": "turbo dev --filter=@wup/web --filter=@wup/api",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.5.0"
}
